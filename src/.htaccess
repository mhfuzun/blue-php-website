# ----------------------------------------------------------------------
# 1. TEMEL GÜVENLİK
# ----------------------------------------------------------------------

# Klasör listelemeyi kapat
Options -Indexes

# UTF-8 karakter seti
AddDefaultCharset UTF-8

# Server signature kapat (Apache versiyon gizleme)
ServerSignature Off

# ----------------------------------------------------------------------
# 2. REWRITE MOTORU
# ----------------------------------------------------------------------

RewriteEngine On

# ----------------------------------------------------------------------
# 3. HASSAS DOSYA VE KLASÖRLERİ KORU
# ----------------------------------------------------------------------

# Kritik klasörleri engelle
RewriteRule ^(src|config|logs|tests|vendor)/ - [F,L]

# Gizli dosyaları engelle (.env, .git vs.)
RewriteRule (^|/)\.(?!well-known/) - [F,L]

# Composer dosyaları
RewriteRule ^composer\.(json|lock)$ - [F,L]

# PHP ini vb.
RewriteRule ^(php\.ini|\.htaccess)$ - [F,L]

# ----------------------------------------------------------------------
# 4. HTTP METHOD GÜVENLİĞİ
# ----------------------------------------------------------------------

# Sadece GET, POST, HEAD izin ver
RewriteCond %{REQUEST_METHOD} !^(GET|POST|HEAD)$
RewriteRule .* - [F]

# ----------------------------------------------------------------------
# 5. DOSYA VARSA DOKUNMA
# ----------------------------------------------------------------------

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# ----------------------------------------------------------------------
# 6. FRONT CONTROLLER (MVC)
# ----------------------------------------------------------------------

RewriteRule ^ index.php [L,QSA]

# ----------------------------------------------------------------------
# 7. GÜVENLİK HEADER'LARI
# ----------------------------------------------------------------------

<IfModule mod_headers.c>

    # XSS koruması
    Header set X-XSS-Protection "1; mode=block"

    # MIME sniffing engelle
    Header set X-Content-Type-Options "nosniff"

    # Clickjacking koruması
    Header set X-Frame-Options "SAMEORIGIN"

    # Referrer policy
    Header set Referrer-Policy "no-referrer-when-downgrade"

    # Basit CSP (isteğe göre sıkılaştırılabilir)
    Header set Content-Security-Policy "default-src 'self'; img-src 'self' data:; script-src 'self'; style-src 'self' 'unsafe-inline'"

</IfModule>

# ----------------------------------------------------------------------
# 8. HATA SAYFALARI (opsiyonel ama önerilir)
# ----------------------------------------------------------------------

ErrorDocument 403 /403.php
ErrorDocument 404 /404.php
